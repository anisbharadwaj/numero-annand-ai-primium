# Secret key for Flask sessions/CSRF
SECRET_KEY=your-secret-key

# Database (SQLite URI or other)
DATABASE_URL=sqlite:///app.db

# Vercel API access token
VERCEL_TOKEN=vercel_access_token_here

# Vercel project ID or name
VERCEL_PROJECT=your_project_id

# (Optional) Vercel team ID if using team scope
VERCEL_TEAM=team_id_here
