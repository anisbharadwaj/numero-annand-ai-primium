</span><span class="ͼv">from</span><span> </span><span class="ͼ11">urllib</span><span class="ͼv">.</span><span class="ͼ11">parse</span><span> </span><span class="ͼv">import</span><span> </span><span class="ͼ11">quote</span><span>

</span><span class="ͼ11">UPI_ID</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"7099805039@ybl"</span><span>
</span><span class="ͼ11">NAME</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼz">"Annand Sarma"</span><span>

</span><span class="ͼv">def</span><span> </span><span class="ͼ11">generate_qr</span><span>(</span><span class="ͼ11">amount</span><span>, </span><span class="ͼ11">note</span><span>):
    </span><span class="ͼ11">upi</span><span> </span><span class="ͼv">=</span><span> (
        </span><span class="ͼz">f"upi://pay?"</span><span>
        </span><span class="ͼz">f"pa=</span><span>{</span><span class="ͼ11">UPI_ID</span><span>}</span><span class="ͼz">"</span><span>
        </span><span class="ͼz">f"&amp;pn=</span><span>{</span><span class="ͼ11">quote</span><span>(</span><span class="ͼ11">NAME</span><span>)}</span><span class="ͼz">"</span><span>
        </span><span class="ͼz">f"&amp;am=</span><span>{</span><span class="ͼ11">amount</span><span>}</span><span class="ͼz">"</span><span>
        </span><span class="ͼz">f"&amp;cu=INR"</span><span>
        </span><span class="ͼz">f"&amp;tn=</span><span>{</span><span class="ͼ11">quote</span><span>(</span><span class="ͼ11">note</span><span>)}</span><span class="ͼz">"</span><span>
    )

    </span><span class="ͼ11">qr</span><span> </span><span class="ͼv">=</span><span> </span><span class="ͼ11">qrcode</span><span class="ͼv">.</span><span>make(</span><span class="ͼ11">upi</span><span>)
    </span><span class="ͼ11">qr</span><span class="ͼv">.</span><span>save(</span><span class="ͼz">"static/images/payment_qr.png"</span><span>)</span></code></pre></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></div></div></div></pre>
